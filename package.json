{
  "name": "encrypted-ct-personality-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build --configLoader native",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "test:contracts": "hardhat test",
    "compile:contracts": "hardhat compile",
    "deploy:base-sepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "seed-missing:base-sepolia": "hardhat run scripts/seed-missing-rounds.ts --network baseSepolia"
  },
  "dependencies": {
    "@cofhe/sdk": "^0.5.2",
    "@privy-io/react-auth": "^2.13.8",
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.9.0",
    "viem": "^2.37.0",
    "vite": "^7.1.0"
  },
  "devDependencies": {
    "@cofhe/hardhat-plugin": "^0.5.2",
    "@cofhe/mock-contracts": "^0.5.2",
    "@fhenixprotocol/cofhe-contracts": "0.1.3",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-toolbox": "^6.0.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "chai": "^6.2.2",
    "eslint": "^9.30.0",
    "hardhat": "^2.26.0",
    "ts-node": "^10.9.2",
    "vercel": "^54.14.0"
  }
